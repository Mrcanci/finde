// Finde — Prisma schema
// Postgres (Supabase) + pgvector + pg_trgm

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector"), pg_trgm, pg_stat_statements, pgcrypto, supabase_vault, uuid_ossp(map: "uuid-ossp")]
}

// ---------- Enums ----------

enum Category {
  adventure
  cultural
  gastronomy
  nature
  mystic
}

enum CancellationPolicy {
  Flexible
  Moderada
  Estricta
  NoReembolsable
}

// ---------- Models ----------

model Operator {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  verified  Boolean  @default(false)
  city      String?
  createdAt DateTime @default(now())

  // M1 sub-paso 8: vínculo con Supabase auth.users (nullable: operadores
  // del seed quedan sin dueño). FK lógica, no la maneja Prisma.
  userId    String?  @unique
  // RUC del operador (persistido desde el onboarding; antes solo se validaba).
  ruc       String?
  // N° de registro MINCETUR enviado por el operador; null = no enviado.
  mincetur  String?

  tours     Tour[]
}

model Tour {
  id            String   @id @default(cuid())
  operatorId    String
  operator      Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  title         String
  description   String   @db.Text
  shortPitch    String?

  titleQu       String?            // traducción quechua del título (null = sin traducir)
  descQu        String?            // traducción quechua de la descripción (null = sin traducir)

  category      Category
  difficulty    String?
  city          String
  region        String

  durationHours Int
  priceSoles    Int      // céntimos de sol (ej: 8500 = S/85.00)
  capacity      Int      @default(10)

  language      String[] @default(["es"])
  included      String[] @default([])
  excluded      String[] @default([])
  includedQu    String[] @default([]) // espeja included en quechua (vacío = sin traducir)
  excludedQu    String[] @default([]) // espeja excluded en quechua (vacío = sin traducir)

  imageUrl      String?            // portada (cards/búsqueda/voucher)
  images        String[] @default([]) // galería multi-foto (Opción A); imageUrl es la portada
  rating        Float    @default(0)
  reviewsCount  Int      @default(0)

  aiSummary     String?
  altTour       Json?
  tags          String[]           @default([])
  badge         String?
  cancellation  CancellationPolicy @default(Moderada)
  meetingPoint  String?
  altitude      Int?
  startTime     String?            // hora de salida "HH:MM" (24h); null = sin definir (legacy)
  active        Boolean            @default(true) // operador pausa/reanuda; el catálogo público filtra active=true
  days          Boolean[]          @default([true, true, true, true, true, true, true])
  excludedDates String[]           @default([])
  addedDates    String[]           @default([])

  embedding     Unsupported("vector(1024)")?

  createdAt     DateTime @default(now())

  bookings      Booking[]

  @@index([category])
  @@index([city])
}

model Booking {
  id           String   @id @default(cuid())
  tourId       String
  // Restrict (no Cascade): borrar un tour con reservas debe FALLAR a nivel DB,
  // no evaporar las reservas en silencio. El handler DELETE /api/tours/[id]
  // valida antes y responde 409 invitando a pausar; este FK es la red de
  // seguridad si algo intenta el borrado por otra vía.
  tour         Tour     @relation(fields: [tourId], references: [id], onDelete: Restrict)

  userEmail    String
  userName     String
  userPhone    String?

  // M1 sub-paso 8: vínculo con Supabase auth.users (nullable: bookings
  // previos al auth quedan sin userId). FK lógica, no la maneja Prisma.
  userId       String?

  guests       Int      @default(1)
  totalSoles   Int      // céntimos de sol (ej: 17000 = S/170.00)

  status       String   @default("confirmed")
  bookingCode  String   @unique
  scheduledAt  DateTime

  createdAt    DateTime @default(now())

  @@index([tourId])
  @@index([userEmail])
  @@index([userId])
}

model SearchLog {
  id         String   @id @default(cuid())
  query      String
  resultIds  String[] @default([])
  reasoning  String?  @db.Text
  createdAt  DateTime @default(now())
}

model FeaturedSearch {
  id              String   @id @default(cuid())
  query           String   @unique
  results         String[] @default([])
  reasoning       String   @db.Text
  filtersDetected Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
