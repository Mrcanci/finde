# Supabase Postgres — copiar ambas connection strings desde el dashboard de Supabase.
# DATABASE_URL es la pooled (puerto 6543, modo "Transaction") — la que usa Prisma client en runtime.
# DIRECT_URL es la direct (puerto 5432) — la que usa `prisma db push` y `prisma migrate`.
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Claude Sonnet 4.6 — re-ranking de búsqueda + generación de descripciones y quechua.
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxx

# Voyage AI — embeddings 1024-dim (modelo voyage-3) para semantic search con pgvector.
# https://dash.voyageai.com/
VOYAGE_API_KEY=pa-xxxx
